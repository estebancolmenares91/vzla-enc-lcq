---
---
<div aria-hidden="true" class="fx-root">
	<div class="fx-radial"></div>
	<div class="fx-grid"></div>
	<div class="fx-scanlines"></div>
	<div class="fx-vignette"></div>
</div>

<style>
	.fx-root {
		position: fixed;
		inset: 0;
		z-index: -10;
		pointer-events: none;
		overflow: hidden;
	}

	.fx-radial {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 80% 60% at 50% 0%, rgba(124, 92, 255, 0.22), transparent 60%),
			radial-gradient(ellipse 60% 40% at 20% 70%, rgba(25, 227, 255, 0.12), transparent 60%),
			radial-gradient(ellipse 60% 40% at 80% 70%, rgba(255, 91, 31, 0.12), transparent 60%),
			#0c0c14;
	}

	.fx-grid {
		position: absolute;
		inset: 60% 0 0 0;
		background-image:
			linear-gradient(to right, rgba(25, 227, 255, 0.10) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(25, 227, 255, 0.10) 1px, transparent 1px);
		background-size: 80px 80px;
		transform: perspective(700px) rotateX(70deg);
		transform-origin: top center;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.7), transparent 85%);
		-webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.7), transparent 85%);
		opacity: 0.45;
	}

	.fx-scanlines {
		position: absolute;
		inset: 0;
		background-image: repeating-linear-gradient(
			0deg,
			transparent 0 2px,
			rgba(255, 255, 255, 0.04) 2px 3px
		);
		opacity: 0.7;
		mix-blend-mode: overlay;
	}

	.fx-vignette {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at center, transparent 50%, rgba(0, 0, 0, 0.65) 100%);
	}
</style>
