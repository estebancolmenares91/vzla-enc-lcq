---
---

<div class="auth-bar" data-auth-bar aria-live="polite">
	<div class="auth-bar-loading">
		<span class="auth-spinner" aria-hidden="true"></span>
		<span class="auth-loading-text">Cargando sesión…</span>
	</div>
</div>

<script>
	import { supabase, SUPABASE_ENABLED } from "../lib/supabase";
	import {
		signInWith,
		signOut,
		onAuthChange,
		getDisplayName,
		getAvatarUrl,
	} from "../lib/auth";
	import type { User } from "@supabase/supabase-js";

	const bar = document.querySelector<HTMLElement>("[data-auth-bar]");
	if (bar) {
		if (!SUPABASE_ENABLED || !supabase) {
			bar.innerHTML = `
				<div class="auth-error">
					Supabase no está configurado. Crea un archivo <code>.env</code> con
					<code>PUBLIC_SUPABASE_URL</code> y <code>PUBLIC_SUPABASE_ANON_KEY</code>.
				</div>
			`;
		} else {
			const renderSignedOut = () => {
				bar.innerHTML = `
					<div class="auth-signedout">
						<span class="auth-eyebrow">Inicia sesión para votar</span>
						<div class="auth-buttons">
							<button type="button" data-signin="google" class="auth-pill auth-pill--google" aria-label="Iniciar sesión con Google">
								<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
									<path fill="#4285F4" d="M22.5 12.27c0-.78-.07-1.53-.2-2.27H12v4.51h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.22-4.74 3.22-8.32Z"/>
									<path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.24 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
									<path fill="#FBBC05" d="M5.84 14.1A6.6 6.6 0 0 1 5.5 12c0-.73.13-1.44.34-2.1V7.07H2.18A11 11 0 0 0 1 12c0 1.78.43 3.46 1.18 4.93l3.66-2.84Z"/>
									<path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z"/>
								</svg>
								<span>Google</span>
							</button>
							<!-- TODO(supabase-twitter): re-enable when Supabase Auth has twitter provider enabled
							<button type="button" data-signin="twitter" class="auth-pill auth-pill--twitter" aria-label="Iniciar sesión con X (Twitter)">
								<svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
									<path fill="currentColor" d="M18.244 2H21l-6.52 7.46L22 22h-6.063l-4.75-6.21L5.7 22H3l7.02-8.02L2 2h6.18l4.29 5.67L18.244 2Zm-2.12 18.26h1.68L7.95 3.62H6.16l9.964 16.64Z"/>
								</svg>
								<span>X</span>
							</button>
							-->
						</div>
					</div>
				`;
				bar
					.querySelectorAll<HTMLButtonElement>("[data-signin]")
					.forEach((b) => {
						b.addEventListener("click", () => {
							const provider = b.dataset.signin as "google" | "twitter" | "twitch";
							signInWith(provider).catch((e: unknown) =>
								console.error("signIn error", e),
							);
						});
					});
			};

			const renderSignedIn = (
				name: string,
				avatar: string | null,
				email: string | null,
			) => {
				bar.innerHTML = `
					<div class="auth-signed">
						${avatar ? `<img src="${avatar}" alt="" class="auth-avatar" referrerpolicy="no-referrer" />` : '<span class="auth-avatar auth-avatar--placeholder" aria-hidden="true">●</span>'}
						<span class="auth-user">
							<span class="auth-name">${name}</span>
							${email ? `<span class="auth-email">${email}</span>` : ""}
						</span>
						<button type="button" data-signout class="auth-signout">Cerrar sesión</button>
					</div>
				`;
				bar
					.querySelector<HTMLButtonElement>("[data-signout]")
					?.addEventListener("click", () => {
						signOut().catch((e: unknown) => console.error("signOut error", e));
					});
			};

			const render = (user: { user_metadata?: unknown; email?: string | null } | null) => {
				if (!user) {
					renderSignedOut();
					return;
				}
				const name = getDisplayName(user as User);
				const avatar = getAvatarUrl(user as User);
				renderSignedIn(name, avatar, user.email ?? null);
			};

			onAuthChange(render);
			supabase.auth.getUser().then(({ data }) => render(data.user));
		}
	}
</script>

<style is:global>
	.auth-bar {
		display: flex;
		justify-content: center;
		margin: 0 0 1rem;
	}

	.auth-bar-loading {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.6rem 1rem;
		font-family: var(--font-body);
		font-size: 0.78rem;
		color: var(--color-ash);
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.auth-spinner {
		width: 14px;
		height: 14px;
		border-radius: 999px;
		border: 2px solid var(--color-ink);
		border-top-color: var(--color-flame);
		animation: spin 0.8s linear infinite;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	@media (prefers-reduced-motion: reduce) {
		.auth-spinner {
			animation: none;
		}
	}

	.auth-signedout,
	.auth-signed {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: 0.65rem;
	}

	.auth-signed {
		flex-direction: row;
		gap: 0.75rem;
	}

	.auth-eyebrow {
		font-family: var(--font-body);
		font-size: 0.7rem;
		letter-spacing: 0.32em;
		color: var(--color-ash);
		text-transform: uppercase;
	}

	.auth-buttons {
		display: inline-flex;
		gap: 0.5rem;
	}

	.auth-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 0.95rem;
		border-radius: 999px;
		font-family: var(--font-body);
		font-weight: 700;
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 200ms, color 200ms, border-color 200ms;
	}

	.auth-pill--google {
		background: #ffffff;
		color: #1f1f1f;
		border: 1px solid #ffffff;
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
	}

	.auth-pill--google:hover,
	.auth-pill--google:focus-visible {
		background: #f2f2f2;
		border-color: #f2f2f2;
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.5);
		outline: none;
	}

	.auth-pill--google:active {
		background: #e6e6e6;
	}

	.auth-pill--twitter {
		background: #ffffff;
		color: #0a0a0a;
		border: 1px solid #ffffff;
		box-shadow:
			0 4px 14px rgba(255, 255, 255, 0.18),
			0 0 0 1px rgba(255, 255, 255, 0.08) inset;
	}

	.auth-pill--twitter:hover,
	.auth-pill--twitter:focus-visible {
		background: #e6e6e6;
		border-color: #e6e6e6;
		box-shadow:
			0 6px 20px rgba(255, 255, 255, 0.28),
			0 0 0 1px rgba(255, 255, 255, 0.12) inset;
		outline: none;
	}

	.auth-pill--twitter:active {
		background: #cccccc;
	}

	.auth-avatar {
		width: 36px;
		height: 36px;
		border-radius: 999px;
		object-fit: cover;
		flex-shrink: 0;
		background: var(--color-ink);
	}

	.auth-avatar--placeholder {
		display: grid;
		place-items: center;
		color: var(--color-flame);
		font-size: 1.1rem;
	}

	.auth-user {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		line-height: 1.2;
	}

	.auth-name {
		font-family: var(--font-body);
		font-weight: 700;
		font-size: 0.92rem;
		color: var(--color-bone);
	}

	.auth-email {
		font-family: var(--font-body);
		font-size: 0.7rem;
		color: var(--color-ash);
		letter-spacing: 0.04em;
	}

	.auth-signout {
		background: transparent;
		color: var(--color-ash);
		border: 1px solid var(--color-ink);
		border-radius: 999px;
		padding: 0.45rem 0.75rem;
		font-family: var(--font-body);
		font-size: 0.7rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		cursor: pointer;
		transition: color 200ms, border-color 200ms;
	}

	.auth-signout:hover,
	.auth-signout:focus-visible {
		color: var(--color-bone);
		border-color: var(--color-bone);
		outline: none;
	}

	.auth-error {
		padding: 0.7rem 1rem;
		font-family: var(--font-body);
		font-size: 0.78rem;
		color: var(--color-flame);
		border: 1px solid rgba(255, 91, 31, 0.4);
		border-radius: 8px;
		background: rgba(255, 91, 31, 0.06);
		max-width: 540px;
		text-align: center;
	}

	.auth-error code {
		font-family: ui-monospace, "Cascadia Code", monospace;
		font-size: 0.72rem;
		color: var(--color-bone);
		background: var(--color-void-2);
		padding: 0.1rem 0.35rem;
		border-radius: 3px;
	}
</style>
