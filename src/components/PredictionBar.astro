---
import { P1, P2, EVENT } from "../data/event.ts";
import AuthBar from "./AuthBar.astro";

const charMap = { deejay: "/chars/deejay.webp", zangief: "/chars/zangief.webp" } as const;
---

<section class="prediction reveal" id="vota" aria-labelledby="prediction-title">
	<header class="pred-head">
		<div class="pred-head-left">
			<p class="pred-eyebrow">PRONÓSTICO DE LA COMUNIDAD</p>
			<h2 id="prediction-title" class="pred-title">
				¿QUIÉN <span class="pred-title-accent">SE LLEVA</span> EL PUESTO?
			</h2>
		</div>
		<div class="pred-head-right">
			<span class="pred-votes-num" data-votes>0</span>
			<span class="pred-votes-label">votos</span>
		</div>
	</header>

	<div
		class="lifebar"
		role="group"
		aria-label="Porcentaje de votos por jugador"
		data-p1={P1.pct}
		data-p2={P2.pct}
	>
		<div class="lifebar-fill lifebar-fill--p1" data-fill="p1" style={`width: ${P1.pct}%`}>
			<div class="lifebar-ticks" aria-hidden="true"></div>
		</div>
		<div class="lifebar-fill lifebar-fill--p2" data-fill="p2" style={`width: ${P2.pct}%`}>
			<div class="lifebar-ticks" aria-hidden="true"></div>
		</div>
		<div class="lifebar-center" aria-hidden="true">
			<span class="lifebar-vs">VS</span>
		</div>
	</div>

	<div class="pred-figures">
		<figure class="pred-figure pred-figure--p1">
			<div class="pred-figure-char">
				<img src={charMap.deejay} alt="" class="pred-figure-char-img" />
			</div>
			<figcaption>
				<div class="pred-figure-name">{P1.name}</div>
				<div class="pred-figure-pct" data-pct="p1">{P1.pct}%</div>
			</figcaption>
		</figure>

		<figure class="pred-figure pred-figure--p2">
			<figcaption>
				<div class="pred-figure-name">{P2.name}</div>
				<div class="pred-figure-pct" data-pct="p2">{P2.pct}%</div>
			</figcaption>
			<div class="pred-figure-char">
				<img src={charMap.zangief} alt="" class="pred-figure-char-img" />
			</div>
		</figure>
	</div>

	<p class="pred-ticker" data-ticker>
		LA COMUNIDAD DICE: <strong data-leader>PELEA TÉCNICA</strong>
	</p>

	<AuthBar />

	<section class="pred-feed" aria-labelledby="pred-feed-title">
		<header class="pred-feed-head">
			<h3 id="pred-feed-title" class="pred-feed-title">Últimos votos de la comunidad</h3>
			<span class="pred-feed-count" data-feed-count>0 aportes</span>
		</header>
		<ul class="pred-feed-list" data-feed-list role="list">
			<li class="pred-feed-empty" data-feed-empty>Cuando alguien vote, aparecerá aquí.</li>
		</ul>
	</section>

	<div class="pred-stage" data-stage="pick">
		<div class="pred-actions">
			<button type="button" class="pred-vote pred-vote--p1" data-pick-vote="p1">
				<img
					src={charMap.deejay}
					alt=""
					class="pred-vote-char"
					aria-hidden="true"
					loading="lazy"
					decoding="async"
				/>
				<span class="pred-vote-label">APOYO A {P1.name}</span>
			</button>
			<button type="button" class="pred-vote pred-vote--p2" data-pick-vote="p2">
				<span class="pred-vote-label">APOYO A {P2.name}</span>
				<img
					src={charMap.zangief}
					alt=""
					class="pred-vote-char"
					aria-hidden="true"
					loading="lazy"
					decoding="async"
				/>
			</button>
		</div>
	</div>

	<div class="pred-stage pred-stage--form" data-stage="form" data-side="p1" hidden>
		<header class="pred-form-head">
			<p class="pred-form-eyebrow">CONFIRMA TU APOYO</p>
			<h3 class="pred-form-title">
				Vas con <span class="pred-form-player" data-form-player>—</span>
			</h3>
		</header>

		<form class="pred-form-body" data-form-el>
			<label class="pred-field">
				<span class="pred-field-label">Tu tag o gamertag</span>
				<input
					type="text"
					name="tag"
					data-input-tag
					placeholder="Ej. mentirouen"
					autocomplete="off"
					required
					minlength="2"
					maxlength="32"
				/>
				<span class="pred-field-hint">
					Este tag viene de tu cuenta. Si quieres, puedes editarlo.
				</span>
			</label>

			<fieldset class="pred-field pred-field--amount">
				<legend class="pred-field-label">¿Cuánto vas a aportar al GoFundMe?</legend>
				<div class="pred-chips" role="group" aria-label="Montos predeterminados">
					<button type="button" class="pred-chip" data-amt="5" aria-pressed="false">$5</button>
					<button type="button" class="pred-chip" data-amt="10" aria-pressed="false">$10</button>
					<button type="button" class="pred-chip" data-amt="25" aria-pressed="false">$25</button>
					<button type="button" class="pred-chip" data-amt="50" aria-pressed="false">$50</button>
				</div>
				<label class="pred-custom-amt">
					<span class="pred-custom-prefix">$</span>
					<input
						type="number"
						name="amount"
						data-input-amt
						placeholder="Custom"
						min="1"
						max="10000"
						step="1"
						inputmode="numeric"
					/>
				</label>
				<span class="pred-field-hint">
					Este monto llega 100% a los nuestros a través de GoFundMe — sin intermediarios.
				</span>
			</fieldset>

			<div class="pred-form-actions">
				<button type="button" class="pred-cancel" data-cancel>← Cambiar jugador</button>
				<button type="submit" class="pred-submit" data-submit>
					<span>Confirmar voto</span>
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path fill="currentColor" d="M5 12h12l-4-4 1.4-1.4L20.8 12l-6.4 5.4L13 16l4-4H5v-1Z" />
					</svg>
				</button>
			</div>
		</form>
	</div>

	<div class="pred-stage pred-stage--done" data-stage="done" hidden>
		<svg class="pred-done-check" viewBox="0 0 24 24" width="36" height="36" aria-hidden="true">
			<path
				fill="none"
				stroke="currentColor"
				stroke-width="3"
				stroke-linecap="round"
				stroke-linejoin="round"
				d="m5 12 5 5 9-11"
			/>
		</svg>
		<p class="pred-done-eyebrow">YA PRONOSTICASTE</p>
		<p class="pred-done-line">
			Apoyas a <strong data-done-player>—</strong> con
			<strong data-done-amount>—</strong>
		</p>
		<p class="pred-done-tag">
			como <strong data-done-tag>—</strong>
		</p>
		<a
			class="pred-done-go"
			href={EVENT.gofundme}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Completar aporte en GoFundMe (abre en nueva pestaña)"
		>
			<span>Completar aporte en GoFundMe</span>
			<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
				<path fill="currentColor" d="M5 12h12l-4-4 1.4-1.4L20.8 12l-6.4 5.4L13 16l4-4H5v-1Z" />
			</svg>
		</a>
	</div>
</section>

<script>
	import type { User } from "@supabase/supabase-js";
	import { supabase, SUPABASE_ENABLED } from "../lib/supabase";
	import {
		signInWith,
		onAuthChange,
		getDisplayName,
	} from "../lib/auth";
	import {
		fetchRecentVotes,
		countVotesBySide,
		fetchMyVote,
		insertVote,
		subscribeVotes,
		isUniqueViolation,
		type Vote,
		type Side,
	} from "../lib/votes";

	type Stage = "pick" | "form" | "done";

	const PLAYER_LABEL: Record<Side, string> = {
		p1: "CELFCOOL",
		p2: "FOREVERCARLONE",
	};

	const CHAR_IMG: Record<Side, string> = {
		p1: "/chars/deejay.webp",
		p2: "/chars/zangief.webp",
	};

	const FEED_LIMIT = 8;
	const STORAGE_KEY = "enc_vote_id_v1";

	const root = document.querySelector<HTMLElement>(".prediction");
	if (root) {
		const fills = {
			p1: root.querySelector<HTMLElement>('[data-fill="p1"]'),
			p2: root.querySelector<HTMLElement>('[data-fill="p2"]'),
		};
		const pcts = {
			p1: root.querySelector<HTMLElement>('[data-pct="p1"]'),
			p2: root.querySelector<HTMLElement>('[data-pct="p2"]'),
		};
		const leaderEl = root.querySelector<HTMLElement>("[data-leader]");
		const votesEl = root.querySelector<HTMLElement>("[data-votes]");
		const stages = {
			pick: root.querySelector<HTMLElement>('[data-stage="pick"]'),
			form: root.querySelector<HTMLElement>('[data-stage="form"]'),
			done: root.querySelector<HTMLElement>('[data-stage="done"]'),
		};
		const formEl = root.querySelector<HTMLFormElement>("[data-form-el]");
		const formPlayer = root.querySelector<HTMLElement>("[data-form-player]");
		const inputTag = root.querySelector<HTMLInputElement>("[data-input-tag]");
		const inputAmt = root.querySelector<HTMLInputElement>("[data-input-amt]");
		const chipButtons = root.querySelectorAll<HTMLButtonElement>("[data-amt]");
		const donePlayer = root.querySelector<HTMLElement>("[data-done-player]");
		const doneAmount = root.querySelector<HTMLElement>("[data-done-amount]");
		const doneTag = root.querySelector<HTMLElement>("[data-done-tag]");
		const feedList = root.querySelector<HTMLElement>("[data-feed-list]");
		const feedEmpty = root.querySelector<HTMLElement>("[data-feed-empty]");
		const feedCount = root.querySelector<HTMLElement>("[data-feed-count]");

		let pct1 = 50;
		let pct2 = 50;
		let p1Count = 0;
		let p2Count = 0;
		let total = 0;
		let currentSide: Side = "p1";
		let currentAmount = 10;
		let currentUser: User | null = null;
		let userRecord: Vote | null = null;
		let unsubscribeRealtime: (() => void) | null = null;

		const escapeHtml = (s: string): string =>
			s
				.replace(/&/g, "&amp;")
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;")
				.replace(/"/g, "&quot;")
				.replace(/'/g, "&#39;");

		const formatAgoIso = (iso: string): string => {
			const diff = (Date.now() - new Date(iso).getTime()) / 60000;
			if (diff < 1) return "ahora";
			if (diff < 60) return `hace ${Math.round(diff)} min`;
			const h = diff / 60;
			if (h < 24) return `hace ${Math.round(h)} h`;
			return `hace ${Math.round(h / 24)} d`;
		};

		const renderFeedItem = (v: Vote): string => `
			<li class="pred-feed-item pred-feed-item--${v.side}">
				<span class="pred-feed-char" aria-hidden="true">
					<img src="${CHAR_IMG[v.side]}" alt="" class="pred-feed-img" loading="lazy" decoding="async" />
				</span>
				<span class="pred-feed-body">
					<span class="pred-feed-tag">${escapeHtml(v.tag)}</span>
					<span class="pred-feed-meta">apoyó a <strong class="pred-feed-gt">${PLAYER_LABEL[v.side]}</strong> · ${formatAgoIso(v.created_at)}</span>
				</span>
				<span class="pred-feed-amount pred-feed-amount--${v.side}">$${v.amount}</span>
			</li>
		`;

		const setBar = () => {
			if (fills.p1) fills.p1.style.width = `${pct1}%`;
			if (fills.p2) fills.p2.style.width = `${pct2}%`;
			if (pcts.p1) pcts.p1.textContent = `${pct1}%`;
			if (pcts.p2) pcts.p2.textContent = `${pct2}%`;
			if (leaderEl) {
				if (pct1 > pct2) leaderEl.textContent = `${PLAYER_LABEL.p1} LLEVA LA VENTAJA`;
				else if (pct2 > pct1)
					leaderEl.textContent = `${PLAYER_LABEL.p2} LLEVA LA VENTAJA`;
				else leaderEl.textContent = "¡PELEA TÉCNICA! IMPASABLE";
			}
		};

		const updateTotals = () => {
			if (votesEl) votesEl.textContent = total.toLocaleString("es-VE");
			if (feedCount)
				feedCount.textContent = `${total} ${total === 1 ? "aporte" : "aportes"}`;
		};

		const recalcPcts = () => {
			const sum = p1Count + p2Count;
			if (sum === 0) {
				pct1 = 50;
				pct2 = 50;
			} else {
				pct1 = Math.round((p1Count / sum) * 100);
				pct2 = 100 - pct1;
			}
			setBar();
		};

		const flash = (side: Side) => {
			const el = side === "p1" ? fills.p2 : fills.p1;
			if (!el) return;
			el.classList.remove("is-hit");
			void el.offsetWidth;
			el.classList.add("is-hit");
			setTimeout(() => el.classList.remove("is-hit"), 250);
		};

		const showStage = (name: Stage) => {
			stages.pick?.toggleAttribute("hidden", name !== "pick");
			stages.form?.toggleAttribute("hidden", name !== "form");
			stages.done?.toggleAttribute("hidden", name !== "done");
		};

		const setActiveChip = (amt: number) => {
			chipButtons.forEach((b) => {
				const v = Number(b.dataset.amt);
				b.classList.toggle("is-active", v === amt);
				b.setAttribute("aria-pressed", v === amt ? "true" : "false");
			});
		};

		const openForm = (side: Side) => {
			if (userRecord) return;
			if (!currentUser) {
				const provider = "google";
				signInWith(provider).catch((e: unknown) => console.error("signIn error", e));
				return;
			}
			currentSide = side;
			if (formPlayer) formPlayer.textContent = PLAYER_LABEL[side];
			stages.form?.setAttribute("data-side", side);
			showStage("form");
			if (inputAmt && !inputAmt.value) inputAmt.value = String(currentAmount);
			setActiveChip(currentAmount);
			if (inputTag && !inputTag.value) {
				inputTag.value = getDisplayName(currentUser);
			}
			setTimeout(() => inputTag?.focus(), 50);
		};

		const cancelForm = () => {
			showStage("pick");
		};

		const submitVote = async () => {
			if (userRecord || !currentUser) return;
			const tag = (inputTag?.value || "").trim();
			const amtRaw = Number(inputAmt?.value || "0");
			const amount = Math.max(1, Math.min(10000, amtRaw || currentAmount));
			if (tag.length < 2) {
				inputTag?.focus();
				return;
			}

			try {
				const vote = await insertVote(
					{ tag, side: currentSide, amount },
					currentUser,
				);
				userRecord = vote;
				try {
					localStorage.setItem(STORAGE_KEY, vote.id);
				} catch (_) { /* noop */ }
				total += 1;
				if (currentSide === "p1") p1Count++;
				else p2Count++;
				updateTotals();
				recalcPcts();
				flash(currentSide);
				if (donePlayer) donePlayer.textContent = PLAYER_LABEL[currentSide];
				if (doneAmount) doneAmount.textContent = `$${amount}`;
				if (doneTag) doneTag.textContent = tag;
				showStage("done");
				prependFeedItem(vote);
			} catch (e: unknown) {
				if (isUniqueViolation(e as Error)) {
					await loadMyVote();
				} else {
					console.error("submitVote error", e);
				}
			}
		};

		const prependFeedItem = (v: Vote) => {
			if (!feedList) return;
			feedEmpty?.remove();
			feedList.insertAdjacentHTML("afterbegin", renderFeedItem(v));
			while (feedList.children.length > FEED_LIMIT) {
				feedList.lastElementChild?.remove();
			}
		};

		const loadFeed = async () => {
			if (!feedList) return;
			try {
				const votes = await fetchRecentVotes(FEED_LIMIT);
				if (votes.length === 0) {
					feedList.innerHTML = `<li class="pred-feed-empty" data-feed-empty>Cuando alguien vote, aparecerá aquí.</li>`;
				} else {
					feedList.innerHTML = votes.map(renderFeedItem).join("");
				}
			} catch (e: unknown) {
				console.error("loadFeed error", e);
				feedList.innerHTML = `<li class="pred-feed-empty">No se pudo cargar la lista.</li>`;
			}
		};

		const loadStats = async () => {
			try {
				const { p1, p2 } = await countVotesBySide();
				p1Count = p1;
				p2Count = p2;
				total = p1 + p2;
				updateTotals();
				recalcPcts();
			} catch (e: unknown) {
				console.error("loadStats error", e);
			}
		};

		const loadMyVote = async () => {
			if (!currentUser) return;
			try {
				const my = await fetchMyVote(currentUser.id);
				if (my) {
					userRecord = my;
					currentSide = my.side;
					if (donePlayer) donePlayer.textContent = PLAYER_LABEL[my.side];
					if (doneAmount) doneAmount.textContent = `$${my.amount}`;
					if (doneTag) doneTag.textContent = my.tag;
					showStage("done");
				}
			} catch (e: unknown) {
				console.error("loadMyVote error", e);
			}
		};

		const initRealtime = () => {
			if (unsubscribeRealtime) return;
			unsubscribeRealtime = subscribeVotes((vote) => {
				if (currentUser && vote.user_id === currentUser.id) return;
				total += 1;
				if (vote.side === "p1") p1Count++;
				else p2Count++;
				updateTotals();
				recalcPcts();
				prependFeedItem(vote);
			});
		};

		chipButtons.forEach((b) => {
			b.addEventListener("click", () => {
				const v = Number(b.dataset.amt);
				if (!Number.isFinite(v)) return;
				currentAmount = v;
				if (inputAmt) inputAmt.value = String(v);
				setActiveChip(v);
			});
		});

		inputAmt?.addEventListener("input", () => {
			const v = Number(inputAmt.value);
			if (Number.isFinite(v) && v > 0) {
				currentAmount = v;
				setActiveChip(v);
			} else {
				setActiveChip(NaN);
			}
		});

		root
			.querySelectorAll<HTMLButtonElement>("[data-pick-vote]")
			.forEach((btn) => {
				btn.addEventListener("click", () => {
					const v = btn.dataset.pickVote as Side | undefined;
					if (v) openForm(v);
				});
			});

		root
			.querySelector<HTMLButtonElement>("[data-cancel]")
			?.addEventListener("click", cancelForm);
		formEl?.addEventListener("submit", (e) => {
			e.preventDefault();
			void submitVote();
		});

		setBar();

		if (SUPABASE_ENABLED && supabase) {
			void loadFeed();
			void loadStats();
			onAuthChange((user) => {
				currentUser = user;
				if (user) {
					void loadMyVote();
				} else {
					userRecord = null;
					try {
						localStorage.removeItem(STORAGE_KEY);
					} catch (_) { /* noop */ }
					showStage("pick");
				}
			});
			supabase.auth.getUser().then(({ data }) => {
				currentUser = data.user;
				if (currentUser) void loadMyVote();
			});
			initRealtime();
		} else {
			// Fallback sin Supabase: ocultar el form para que el usuario sepa que no puede votar
			stages.pick?.setAttribute("hidden", "");
			const msg = document.createElement("p");
			msg.className = "pred-feed-empty";
			msg.style.textAlign = "center";
			msg.style.color = "var(--color-flame)";
			msg.textContent = "Las votaciones están deshabilitadas. Configura Supabase para habilitarlas.";
			stages.pick?.parentElement?.insertBefore(msg, stages.pick);
		}
	}
</script>

<style is:global>
	.prediction {
		position: relative;
		max-width: 1100px;
		margin: 2.5rem auto 4rem;
		padding: 1.75rem 1.5rem 2rem;
		background: transparent;
		border: 0;
		border-radius: 10px;
	}

	.pred-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1rem;
		margin-bottom: 1.25rem;
		flex-wrap: wrap;
	}

	.pred-eyebrow {
		margin: 0 0 0.4rem;
		font-family: var(--font-body);
		font-size: 0.7rem;
		letter-spacing: 0.42em;
		color: var(--color-ash);
		text-transform: uppercase;
	}

	.pred-title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 2.6vw, 2rem);
		text-transform: uppercase;
		letter-spacing: -0.01em;
		line-height: 1;
	}

	.pred-title-accent {
		background: linear-gradient(90deg, var(--color-cyan), var(--color-flame));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.pred-head-right {
		display: flex;
		align-items: baseline;
		gap: 0.35rem;
		color: var(--color-ash);
		font-family: var(--font-body);
	}

	.pred-votes-num {
		font-family: var(--font-display);
		font-size: 1.1rem;
		color: var(--color-bone);
		letter-spacing: 0.05em;
	}

	.pred-votes-label {
		font-size: 0.7rem;
		letter-spacing: 0.3em;
		text-transform: uppercase;
	}

	.lifebar {
		position: relative;
		display: flex;
		width: 100%;
		height: 56px;
		border: 1px solid var(--color-ink);
		border-radius: 6px;
		overflow: hidden;
		background: var(--color-void-2);
		box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.6);
	}

	.lifebar-fill {
		position: relative;
		height: 100%;
		transition: width 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.lifebar-fill--p1 {
