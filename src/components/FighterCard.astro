---
interface Props {
	side: "left" | "right";
	player: {
		name: string;
		gt: string;
		char: string;
		charImg: string;
		record: string;
		accent: "cyan" | "flame";
	};
}

const { side, player } = Astro.props;

const charMap: Record<string, string> = {
	deejay: "/chars/deejay.webp",
	zangief: "/chars/zangief.webp",
};

const charSrc = charMap[player.charImg] ?? charMap.deejay;
const isLeft = side === "left";
const accentText = isLeft ? "text-cyan" : "text-flame";
const accentBorder = isLeft ? "border-cyan" : "border-flame";
const charShadow = isLeft
	? "drop-shadow(0 0 28px rgba(25,227,255,0.55))"
	: "drop-shadow(0 0 28px rgba(255,91,31,0.6))";
---

<div class={`fighter-card ${side}`} data-side={side} data-accent={player.accent}>
	<div class="char-stage">
		<img
			src={charSrc}
			alt=""
			class="char-img"
			style={`filter: ${charShadow};`}
			loading="eager"
			decoding="async"
		/>
	</div>

	<div class="meta">
		<div class={`meta-name ${accentText}`}>{player.name}</div>
		<div class={`char-chip ${accentBorder}`}>
			<span class="chip-key">CHAR</span>
			<span>{player.char}</span>
		</div>
	</div>
</div>

<style>
	.fighter-card {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.25rem;
		padding: 1rem 1rem 1.5rem;
		width: 100%;
		min-height: 100%;
	}

	.char-stage {
		width: clamp(220px, 24vw, 340px);
		height: clamp(220px, 24vw, 340px);
		display: grid;
		place-items: center;
		pointer-events: none;
	}

	.char-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.meta {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-align: center;
	}

	.meta-name {
		font-family: var(--font-display);
		font-size: clamp(2rem, 3.4vw, 2.75rem);
		text-transform: uppercase;
		letter-spacing: -0.01em;
		line-height: 1;
	}

	.char-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.3rem 0.7rem;
		border-width: 1px;
		border-style: solid;
		font-family: var(--font-body);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-bone);
	}

	.chip-key {
		color: var(--color-ash);
	}

	.fighter-card.left .char-chip {
		border-color: var(--color-cyan);
	}
	.fighter-card.right .char-chip {
		border-color: var(--color-flame);
	}

	@media (max-width: 1024px) {
		.fighter-card {
			flex-direction: row;
			justify-content: center;
			gap: 1.25rem;
		}
		.char-stage {
			width: 180px;
			height: 180px;
			flex-shrink: 0;
		}
		.meta {
			align-items: flex-start;
			text-align: left;
		}
	}

	@media (max-width: 640px) {
		.fighter-card {
			padding: 0.5rem 0.5rem 1rem;
		}
		.char-stage {
			width: 140px;
			height: 140px;
		}
		.meta-name {
			font-size: 1.5rem;
		}
	}
</style>
